---
import Layout from "../../layouts/Layout.astro";
import PortableText from "../../components/PortableText.astro";
import { client } from "../../lib/sanity";

export async function getStaticPaths() {
  const works = await client.fetch(
    `*[_type == "work" && defined(slug.current)]{ "slug": slug.current }`,
  );
  return works.map(({ slug }: { slug: string }) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const work = await client.fetch(
  `*[_type == "work" && slug.current == $slug][0]{
  title,
  "seoTitle": seo.title,
  credits[]{role, names},
  client,
  projectImages[]{
    "url": asset->url,
    "dimensions": asset->metadata.dimensions,
    alt,
    caption
  },
  content[]{
    ...,
    _type == "image" => {
      "url": asset->url,
      "dimensions": asset->metadata.dimensions,
      alt,
      caption
    }
  }
}`,
  { slug },
);

if (!work) return Astro.redirect("/selected-work");
---

<Layout title={work.seoTitle ?? work.title}>
  <main class="pt-24 lg:pt-40 pb-20 mx-auto">
    <div class="lg:grid grid-cols-12 gap-5 border-b border-brand pb-4 lg:pb-8">
      <div class="col-span-10">
        <h1 class="heading-1">
          <span class="block">{work.client}:</span>
          <span class="block">{work.title}</span>
        </h1>
      </div>
    </div>

    <div class="lg:grid grid-cols-12 gap-5 body-1 pt-4 lg:pt-8">
      <div class="col-span-4">
        {
          work.credits?.length > 0 && (
            <dl class="grid lg:grid-cols-2 gap-4 lg:gap-x-5 mb-8">
              {work.credits.map(
                ({ role, names }: { role: string; names: string }) => (
                  <div class="">
                    <dt class="shrink-0 body-1 mt-1 text-semantic-secondary uppercase">
                      {role}
                    </dt>
                    <dd class="mt-1">
                      {names.split(", ").map((name) => (
                        <p>{name}</p>
                      ))}
                    </dd>
                  </div>
                ),
              )}
            </dl>
          )
        }
      </div>
      <div class="col-span-7 lg:col-start-6">
        <div class="max-w-[760px]">
          {
            work.content?.some((b: any) => b._type === "block") && (
              <PortableText
                value={work.content.filter((b: any) => b._type === "block")}
                layout={false}
                normalClass="body-2"
              />
            )
          }
        </div>
        {
          work.projectImages?.length > 0 && (
            <div class="flex flex-col gap-16 mt-16">
              {work.projectImages.map((img: any) => (
                <figure>
                  <img
                    src={img.url}
                    alt={img.alt ?? ""}
                    class="w-full"
                    width={img.dimensions?.width}
                    height={img.dimensions?.height}
                  />
                  {img.caption && (
                    <figcaption class="body-2 text-[var(--color-semantic-text-muted)] mt-3">
                      {img.caption}
                    </figcaption>
                  )}
                </figure>
              ))}
            </div>
          )
        }
      </div>
      <div class="col-span-12"></div>
    </div>
  </main>
</Layout>
