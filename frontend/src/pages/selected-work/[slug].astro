---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../../components/PortableText.astro'
import { client } from '../../lib/sanity'

export async function getStaticPaths() {
  const works = await client.fetch(`*[_type == "work" && defined(slug.current)]{ "slug": slug.current }`)
  return works.map(({ slug }: { slug: string }) => ({ params: { slug } }))
}

const { slug } = Astro.params

const work = await client.fetch(`*[_type == "work" && slug.current == $slug][0]{
  title,
  "seoTitle": seo.title,
  credits[]{role, names},
  projectImages[]{
    "url": asset->url,
    "dimensions": asset->metadata.dimensions,
    alt,
    caption
  },
  content[]{
    ...,
    _type == "image" => {
      "url": asset->url,
      "dimensions": asset->metadata.dimensions,
      alt,
      caption
    }
  }
}`, { slug })

if (!work) return Astro.redirect('/selected-work')
---

<Layout title={work.seoTitle ?? work.title}>
  <main class="px-4 lg:px-8 pt-40 pb-20 mx-auto">
    <div class="lg:grid grid-cols-12">
      <div class="col-span-7">
        <h1 class="display mb-16">{work.title}</h1>
      </div>
    </div>

    <div class="lg:grid grid-cols-12 gap-8">
      <div class="col-span-12">
        {work.credits?.length > 0 && (
          <dl class="flex flex-col gap-1 mb-8">
            {work.credits.map(({ role, names }: { role: string; names: string }) => (
              <div class="flex gap-4">
                <dt class="body-2 text-[var(--color-semantic-text-muted)] shrink-0">{role}:</dt>
                <dd class="body-2">{names}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>
      <div class="col-span-5">
        {work.content?.some((b: any) => b._type === 'block') && (
          <PortableText value={work.content.filter((b: any) => b._type === 'block')} layout={false} />
        )}
      </div>
      <div class="col-start-7 col-span-6">
            {work.projectImages?.length > 0 && (
      <div class="flex flex-col gap-4 mb-16">
        {work.projectImages.map((img: any) => (
          <figure>
            <img
              src={img.url}
              alt={img.alt ?? ''}
              class="w-full"
              width={img.dimensions?.width}
              height={img.dimensions?.height}
            />
            {img.caption && (
              <figcaption class="body-2 text-[var(--color-semantic-text-muted)] mt-3">
                {img.caption}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    )}
      </div>

    </div>

  </main>
</Layout>
