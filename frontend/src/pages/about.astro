---
import Layout from "../layouts/Layout.astro";
import Experience from "../components/Experience.astro";
import { client } from "../lib/sanity";

const about = await client.fetch(`*[_type == "about" && _id == "about"][0]{
  heading,
  skills,
  "seoTitle": seo.title,
  "image": image.asset->{ url, metadata { dimensions } },
  content[]{
    ...,
    _type == "image" => {
      "url": asset->url,
      "dimensions": asset->metadata.dimensions,
      alt,
      caption
    }
  }
}`);
---

<Layout title={about?.seoTitle ?? about?.heading ?? "About"}>
  <main class="pt-40 mx-auto">
    <div class="grid lg:grid-cols-12 gap-y-10 gap-5">
      <div class="lg:col-span-12">
        <div class="grid lg:grid-cols-12 gap-5">
          <div class="lg:col-span-12 lg:pb-20">
            <h1 class="heading-1">
              Hi, I am Mila,<br />a Creative Leader and Brand Strategist.
            </h1>
          </div>
        </div>
      </div>
      <div class="lg:col-span-3 lg:col-start-2">
        {
          about?.image?.url && (
            <div class="lg:sticky top-20">
              <img
                src={about.image.url}
                alt={about.image.alt ?? "Mila Linares"}
                class="w-full h-auto object-cover"
              />
            </div>
          )
        }
      </div>
      <div class="lg:col-span-7 lg:col-start-6">
        <div class="max-w-[760px]">
          <div class="prose body-2 leading-[150%]">
            <p>
              With roots in Spain, I have called CDMX, Paris, and Rotterdam home
              before settling in the ample hills of Brooklyn. I believe in brand
              strategy’s ability to identify what remains true, to clarify what
              matters most, and to bring it to life in ordinary and
              extraordinary ways.
            </p>

            <p>
              For the past 20 years, I have helped American Express broaden its
              appeal to a new generation of customers, Wikipedia draft a story
              to ground future growth, and Google refine its storytelling for
              businesses. My experience on the creative agency and the client
              side gives me the ability to deliver outstanding creative work,
              and the stamina to make it happen while building resilient and
              joyful teams.
            </p>

            <p>
              I currently serve as Chief of Brand at UNICEF, bringing our brand
              to life across a wide variety of contexts and partners from the
              field to the political arena and everywhere in between.
            </p>
          </div>
        </div>
        <Experience />
      </div>
    </div>
  </main>
</Layout>
