---
import Layout from '../layouts/Layout.astro'
import PortableText from '../components/PortableText.astro'
import { client } from '../lib/sanity'

const about = await client.fetch(`*[_type == "about" && _id == "about"][0]{
  heading,
  skills,
  "seoTitle": seo.title,
  "image": image.asset->{ url, metadata { dimensions } },
  content[]{
    ...,
    _type == "image" => {
      "url": asset->url,
      "dimensions": asset->metadata.dimensions,
      alt,
      caption
    }
  }
}`)
---

<Layout title={about?.seoTitle ?? about?.heading ?? 'About'}>
  <main class="pt-40 pb-20 mx-auto">
    <div class="grid grid-cols-8 gap-4">
      <div class="col-span-3">
        {about?.heading && <h1 class="body-2 mb-8 leading-[150%]">{about.heading}</h1>}
      </div>
      <div class="col-span-5 prose body-2 leading-[150%]">
        <p>Hi, I'm Mila.</p>
        <p>I'm a strategist who believes the best work sits at the intersection of bold vision and rigorous thinking. I help brands find their footing — whether that means shaping a long-term strategy, building the story from the ground up, or activating ideas that move people.</p>
        <p>I've led strategy across brand, marketing, and social impact — working with global organizations to drive growth, build culture, and create meaningful change. My practice spans Vision & Long-Term Strategy, Brand Storytelling, Integrated Marketing, and Community Engagement, with a deep commitment to responsible business and social impact.</p>
        <p>I work best in the space between complexity and clarity — where the brief is hard, the stakes are real, and the answer isn't obvious yet.</p>
      </div>
    </div>
    <div class="grid grid-cols-8 gap-4 mt-40">
      <div class="col-span-3">
        {about?.heading && <h2 class="body-2 mb-8 leading-[150%]">Curiculum Verite</h2>}
      </div>
      <div class="col-span-5">
        {about?.content?.length > 0 && (
          <div>
            {about.content?.some((b: any) => b._type === 'block') && (
              <PortableText value={about.content.filter((b: any) => b._type === 'block')} layout={false} normalClass='body-1' />
            )}
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>
