---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>history.scrollRestoration = 'manual'</script>
  </head>
  <body>
    <div id="page-content" class="relative z-10 bg-(--color-semantic-background)">
      <Header />
      <slot />
    </div>
    <Footer />
  </body>
  <script>
    import Lenis from 'lenis'

    const footer = document.getElementById('site-footer') as HTMLElement
    const pageContent = document.getElementById('page-content') as HTMLElement

    const syncMargin = () => {
      pageContent.style.marginBottom = `${footer.offsetHeight}px`
    }
    syncMargin()
    window.addEventListener('resize', syncMargin)

    const header = document.getElementById('site-header') as HTMLElement
    let lastScroll = 0
    let hidden = false

    const lenis = new Lenis()
    lenis.stop()

    if (document.getElementById('intro')) {
      lenis.scrollTo(0, { immediate: true })
      window.addEventListener('intro:done', () => lenis.start(), { once: true })
    } else {
      lenis.start()
    }

    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      const delta = scroll - lastScroll
      lastScroll = scroll

      if (scroll < 80) {
        if (hidden) { header.style.transform = ''; hidden = false }
        return
      }

      if (delta > 0 && !hidden) {
        header.style.transform = `translateY(-100%)`
        hidden = true
      } else if (delta < 0 && hidden) {
        header.style.transform = ''
        hidden = false
      }
    })

    function raf(time: number) {
      lenis.raf(time)
      requestAnimationFrame(raf)
    }
    requestAnimationFrame(raf)

  </script>
</html>
