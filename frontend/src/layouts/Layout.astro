---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GridOverlay from "../components/GridOverlay.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-neue-montreal" />
    <ClientRouter />
    <script is:inline>
      history.scrollRestoration = "manual";
    </script>
  </head>
  <body>
    <GridOverlay />
    <div id="page-content" class="relative">
      <Header />
      <div class="container">
        <slot />
      </div>
    </div>
    <Footer />
  </body><script>
    import Lenis from "lenis";

    const header = document.getElementById("site-header") as HTMLElement;
    let lastScroll = 0;
    let hidden = false;

    const lenis = new Lenis();
    lenis.stop();

    if (document.getElementById("intro")) {
      lenis.scrollTo(0, { immediate: true });
      window.addEventListener("intro:done", () => lenis.start(), {
        once: true,
      });
    } else {
      lenis.start();
    }

    lenis.on("scroll", ({ scroll }: { scroll: number }) => {
      const delta = scroll - lastScroll;
      lastScroll = scroll;

      if (scroll < 80) {
        if (hidden) {
          header.style.transform = "";
          hidden = false;
        }
        return;
      }

      if (delta > 0 && !hidden) {
        header.style.transform = `translateY(-100%)`;
        hidden = true;
      } else if (delta < 0 && hidden) {
        header.style.transform = "";
        hidden = false;
      }
    });

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    document.addEventListener("astro:after-swap", () => {
      lenis.scrollTo(0, { immediate: true });
    });

    const applyGrid = () => {
      const gridToggle = document.getElementById("grid-toggle") as HTMLElement;
      const gridOverlay = document.querySelector(
        ".grid-overlay",
      ) as HTMLElement;
      const iconEye = document.getElementById("grid-icon-eye") as HTMLElement;
      const iconEyeClosed = document.getElementById(
        "grid-icon-eye-closed",
      ) as HTMLElement;
      if (!gridToggle) return;

      const gridVisible = localStorage.getItem("grid-overlay") === "true";
      if (gridOverlay) gridOverlay.style.display = gridVisible ? "" : "none";
      iconEye.classList.toggle("hidden", !gridVisible);
      iconEyeClosed.classList.toggle("hidden", gridVisible);
      gridToggle.setAttribute("aria-pressed", String(gridVisible));

      gridToggle.addEventListener(
        "click",
        () => {
          const current = localStorage.getItem("grid-overlay") === "true";
          localStorage.setItem("grid-overlay", String(!current));
          applyGrid();
        },
        { once: true },
      );
    };

    document.addEventListener("astro:page-load", applyGrid);
  </script>
</html>
