---
import PortableText from '../PortableText.astro'

interface Props {
  body?: any[]
  image?: { url: string; dimensions?: { width: number; height: number } }
}

const { body } = Astro.props
---

<section class="grid lg:grid-cols-12 gap-4 items-center pt-52 pb-20">
  <div class="col-start-7 col-span-6">
    <div id="hero-text" style="opacity:0;transform:translateY(32px)">
      {body && <PortableText value={body} layout={false} normalClass="heading-5 mt-auto" />}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'

  const animate = () => {
    gsap.to('#hero-text', {
      opacity: 1,
      y: 0,
      duration: 0.9,
      delay: 0.35,
      ease: 'power3.out',
    })
    gsap.to('#hero-image', {
      opacity: 1,
      y: 0,
      duration: 1.1,
      delay: 0.5,
      ease: 'power3.out',
    })
  }

  if (document.getElementById('intro')) {
    window.addEventListener('intro:reveal', animate, { once: true })
  } else {
    animate()
  }
</script>
