---
import Eyebrow from "./Eyebrow.astro";
import ArrowButton from "./ArrowButton.astro";

const year = new Date().getFullYear();

const socials = [
  { label: "Instagram", href: "#" },
  { label: "LinkedIn", href: "#" },
  { label: "Twitter", href: "#" },
];
---

<footer
  id="site-footer"
  class="w-full pt-20 lg:pt-40 pb-8 bg-(--color-semantic-background) z-0"
>
  <div class="container">
    <p
      class="text-[clamp(3rem,6vw,6vw)] text-brand mb-8 lg:mt-32 leading-[120%]"
    >
      Let's work together.
    </p>
    <ArrowButton href="mailto:linares.milagro@gmail.com" label="Say Hi" />

    <div
      class="mb-8 mt-6 lg:mt-32 border-t border-brand pt-8 grid lg:grid-cols-12 text-brand gap-5"
    >
      <div class="lg:col-span-3">
        <Eyebrow>Contact</Eyebrow>
      </div>

      <div class="col-span-2">
        <div class="grid grid-cols-2 gap-5">
          <p>Mail</p>
          <p>
            <a href="mailto:linares.milagro@gmail.com"
              >linares.milagro@gmail.com</a
            >
          </p>
          <p>LinkedIn</p>
          <p>
            <a
              href="https://www.linkedin.com/in/mila-linares-83354013/"
              class="inline-flex gap-2"
              target="_blank"><span>Mila_Linares</span> <span>&#8599;</span></a
            >
          </p>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col lg:flex-row justify-between border-brand pt-40 label gap-8"
    >
      <p class="order-last lg:order-[unset]">© {year} Mila Linares</p>
      <p class="order-last lg:order-[unset]">
        Site by <a href="https://brittonwalker.site/" target="_blank">BW</a>
      </p>
    </div>
  </div>
</footer>
