---
import Eyebrow from "./Eyebrow.astro";
const expertise = [
  "Brand Architecture",
  "Visual Expression",
  "Brand Narrative",
  "Brand Strategy",
  "Integrated Brand Campaigns",
  "Brand Health Tracking",
];
---

<section class="pt-40">
  <div class="grid-grid-cols-2 gap-5">
    <div class="col-span-2 lg:col-span-1">
      <Eyebrow>Selected Experience</Eyebrow>
      <ul class="heading-3 pt-4">
        {expertise.map((item) => <li class="">{item}</li>)}
      </ul>
    </div>
  </div>
</section>
