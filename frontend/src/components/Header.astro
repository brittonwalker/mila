---
import { client } from '../lib/sanity'

const nav = await client.fetch(`*[_type == "navigation" && _id == "navigation"][0]{
  links[]{
    label,
    linkType,
    "href": select(
      linkType == "page" => "/" + page->slug.current,
      linkType == "custom" => url
    )
  }
}`)

const links = nav?.links ?? []
---

<header id="site-header" class="fixed top-0 left-0 w-full flex items-center justify-between px-8 py-4 transition-transform duration-300 ease-in-out z-50">
  <a href="/" class="text-brand text-[36px] font-normal tracking-tight">Mila Linares</a>
  {links.length > 0 && (
    <nav>
      <ul class="text-[18px] flex gap-8">
        {links.map(({ label, href }: { label: string; href: string }) => (
          <li>
            <a href={href} class="hover:opacity-60 transition-opacity">{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  )}
</header>
