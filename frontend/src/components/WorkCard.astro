---
interface Props {
  title: string;
  slug: string;
  client?: string;
  coverImage?: {
    url: string;
    dimensions?: { width: number; height: number };
    caption?: string;
  };
}

const { title, client, slug, coverImage } = Astro.props;
---

<a href={`/selected-work/${slug}`} class="group block">
  <div class="mb-4">
    <figure class="relative aspect-[4/3] w-full overflow-hidden bg-neutral-100">
      {
        coverImage?.url ? (
          <img
            src={coverImage.url}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            width={coverImage.dimensions?.width}
            height={coverImage.dimensions?.height}
          />
        ) : (
          <div class="w-full h-full bg-brand" />
        )
      }
      {
        coverImage?.caption && (
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent px-4 pt-8 pb-3 text-white text-[13px] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            {coverImage.caption}
          </figcaption>
        )
      }
    </figure>
  </div>
  <p class="body-2">{title}</p>
  <p class="body-2">{client}</p>
</a>
