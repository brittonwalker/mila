---

<div
  id="cat-head"
  class="block"
  style="animation: bob 3s ease-in-out infinite;"
>
  <style>
    @keyframes bob {
      0%,
      100% {
        transform: translateY(10%);
      }
      50% {
        transform: translateY(0px);
      }
    }
  </style>
  <svg viewBox="0 0 98 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M0.5 119.431H97.3884V0.540527C72.8433 0.540527 66.7071 19.7837 66.7071 29.4052H31.585C31.585 8.25123 10.8617 1.34793 0.5 0.540527V119.431Z"
      fill="#002FA7"
      stroke="#002FA7"></path>
    <!-- left eye white -->
    <path
      id="socket-left"
      d="M31.9094 49.7563C23.1863 49.7563 18.4094 57.4409 17.1113 61.2832C17.7863 65.0736 21.6909 72.6544 31.9094 72.6544C42.1278 72.6544 46.344 65.0736 47.1748 61.2832C45.7209 57.4409 40.6325 49.7563 31.9094 49.7563Z"
      fill="#FAFBFD"></path>
    <!-- left pupil -->
    <path
      id="pupil-left"
      d="M38.7385 72.6543C45.0616 72.6543 50.1875 67.5284 50.1875 61.2053C50.1875 54.8822 45.0616 49.7563 38.7385 49.7563C32.4154 49.7563 27.2896 54.8822 27.2896 61.2053C27.2896 67.5284 32.4154 72.6543 38.7385 72.6543Z"
      fill="#002FA7"></path>
    <!-- right eye white -->
    <path
      id="socket-right"
      d="M75.2473 49.7563C66.5242 49.7563 61.7473 57.4409 60.4492 61.2832C61.1242 65.0736 65.0288 72.6544 75.2473 72.6544C85.4657 72.6544 89.6819 65.0736 90.5126 61.2832C89.0588 57.4409 83.9703 49.7563 75.2473 49.7563Z"
      fill="#FAFBFD"></path>
    <!-- right pupil -->
    <path
      id="pupil-right"
      d="M82.0764 72.6543C88.3995 72.6543 93.5254 67.5284 93.5254 61.2053C93.5254 54.8822 88.3995 49.7563 82.0764 49.7563C75.7533 49.7563 70.6274 54.8822 70.6274 61.2053C70.6274 67.5284 75.7533 72.6543 82.0764 72.6543Z"
      fill="#002FA7"></path>
  </svg>
</div>

<script>
  const init = () => {
    const head = document.getElementById("cat-head");
    const pupilLeft = document.getElementById("pupil-left");
    const pupilRight = document.getElementById("pupil-right");
    const socketLeft = document.getElementById("socket-left");
    const socketRight = document.getElementById("socket-right");
    if (!head || !pupilLeft || !pupilRight || !socketLeft || !socketRight)
      return;

    const svg = head.querySelector("svg") as SVGSVGElement;

    const getCenter = (el: Element) => {
      const box = (el as SVGGraphicsElement).getBBox();
      return { x: box.x + box.width / 2, y: box.y + box.height / 2 };
    };

    const leftOffset = (() => {
      const s = getCenter(socketLeft);
      const p = getCenter(pupilLeft);
      return { x: s.x - p.x, y: s.y - p.y };
    })();
    const rightOffset = (() => {
      const s = getCenter(socketRight);
      const p = getCenter(pupilRight);
      return { x: s.x - p.x, y: s.y - p.y };
    })();

    const applyPupil = (pupil: Element, offset: { x: number; y: number }, tx: number, ty: number) => {
      (pupil as SVGElement).style.transformBox = "fill-box";
      (pupil as SVGElement).style.transformOrigin = "center";
      (pupil as SVGElement).style.transform = `translate(${offset.x + tx}px, ${offset.y + ty}px)`;
    };

    document.addEventListener("mousemove", (e) => {
      const svgRect = svg.getBoundingClientRect();
      const midX = (getCenter(socketLeft).x + getCenter(socketRight).x) / 2;
      const midY = (getCenter(socketLeft).y + getCenter(socketRight).y) / 2;

      const cursorSvgX = ((e.clientX - svgRect.left) / svgRect.width) * 98;
      const cursorSvgY = ((e.clientY - svgRect.top) / svgRect.height) * 120;

      const angle = Math.atan2(cursorSvgY - midY, cursorSvgX - midX);
      const dist = Math.min(Math.hypot(cursorSvgX - midX, cursorSvgY - midY), 4);

      const tx = Math.cos(angle) * dist;
      const ty = Math.sin(angle) * dist;

      applyPupil(pupilLeft, leftOffset, tx, ty);
      applyPupil(pupilRight, rightOffset, tx, ty);
    });
  };

  document.addEventListener("astro:page-load", init);
</script>
